/**app.wxss**/
/* 全局样式 */

/* 重置样式 * {
  box-sizing: border-box;
}*/


page {
  background: linear-gradient(180deg, #0F9D58 0%, #A5D6A7 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'Segoe UI', Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

/* 容器样式 */
.container {
  padding: 20rpx;
}

.page-container {
  min-height: 100vh;
  background-color: transparent;
}

/* 卡片样式 */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.card-content {
  color: #666;
  line-height: 1.5;
}

/* 按钮样式 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  cursor: pointer;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.btn-primary {
  background: linear-gradient(90deg, #0F9D58 0%, #81C784 100%);
  color: #ffffff;
}

.btn-primary:hover {
  filter: brightness(1.06);
}

.btn-secondary {
  background-color: #f5f5f5;
  color: #666;
  border: 1rpx solid #e0e0e0;
}

.btn-secondary:hover {
  background-color: #eeeeee;
}

.btn-success {
  background: linear-gradient(90deg, #2E7D32 0%, #81C784 100%);
  color: #ffffff;
}

.btn-warning {
  background-color: #ffcc80;
  color: #000;
}

.btn-danger {
  background-color: #ef9a9a;
  color: #000;
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

.btn-large {
  padding: 28rpx 40rpx;
  font-size: 32rpx;
}

.btn-block {
  width: 100%;
  display: block;
}

.btn-disabled {
  opacity: 0.6;
  pointer-events: none;
}

/* 表单样式 */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #fff;
}

.form-input:focus {
  border-color: #0F9D58;
  outline: none;
}

.form-textarea {
  width: 100%;
  padding: 24rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #fff;
  min-height: 120rpx;
  resize: vertical;
}

.form-error {
  color: #f44336;
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* 列表样式 */
.list {
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.list-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.list-item-desc {
  font-size: 26rpx;
  color: #999;
}

.list-item-arrow {
  width: 24rpx;
  height: 24rpx;
  margin-left: 16rpx;
}

/* 状态样式 */
.status {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-pending {
  background-color: #fff3e0;
  color: #f57c00;
}

.status-accepted {
  background-color: #e0f2f1;
  color: #0F9D58;
}

.status-in_progress {
  background-color: #e0f2f1;
  color: #2E7D32;
}

.status-completed {
  background-color: #e8f5e9;
  color: #2E7D32;
}

.status-cancelled {
  background-color: #ffebee;
  color: #d32f2f;
}

/* 展示层状态（派生） */
.status-prepay_pending { background-color: #e0f2f1; color: #0F9D58; }
.status-waiting_accept { background-color: #fff8e1; color: #f57c00; }
.status-repair_pay_pending { background-color: #e0f7fa; color: #0F9D58; }
.status-pending_review { background-color: #fffde7; color: #f57f17; }
.status-closed { background-color: #ffebee; color: #d32f2f; }
.status-cancel_pending { background-color: #ffebee; color: #d32f2f; }

/* 工具类 */
.text-center {
  text-align: center;
}

.text-left {
  text-align: left;
}

.text-right {
  text-align: right;
}

.text-primary {
  color: #0F9D58;
}

/* 毛玻璃效果容器（用于自定义底部栏或浮层）*/
